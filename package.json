{
  "name": "discord-bot-scaffold",
  "version": "0.1.0",
  "private": true,
  "description": "A small, extensible Discord bot scaffold built with TypeScript and discord.js.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "pnpm typecheck && pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.3.0",
  "dependencies": {
    "discord.js": "^14.27.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
